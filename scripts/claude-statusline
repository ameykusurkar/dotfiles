#!/bin/sh

input=$(cat)

model=$(echo "$input" | jq -r '.model.display_name // "Claude"')
project_dir=$(echo "$input" | jq -r '.workspace.current_dir // ""')
project=$(basename "$project_dir")
used=$(echo "$input" | jq -r '.context_window.used_percentage // empty')

branch=$(git -C "$project_dir" symbolic-ref --short HEAD 2>/dev/null)

if [ -n "$used" ]; then
  used_int=$(printf "%.0f" "$used")
  if [ "$used_int" -ge 70 ]; then
    context_str="\033[31m${used_int}%\033[0m"
  elif [ "$used_int" -ge 30 ]; then
    context_str="\033[33m${used_int}%\033[0m"
  else
    context_str="\033[32m${used_int}%\033[0m"
  fi
else
  context_str="?"
fi

if [ -n "$branch" ]; then
  echo "[${model}] ${project} | ${branch} | ${context_str}"
else
  echo "[${model}] ${project} | ${context_str}"
fi
