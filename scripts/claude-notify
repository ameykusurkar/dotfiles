#!/bin/bash
INPUT=$(cat)
EVENT=$(echo "$INPUT" | jq -r '.hook_event_name')
PROJECT=$(echo "$INPUT" | jq -r '.cwd' | xargs basename)

case "$EVENT" in
  PermissionRequest)
    TOOL=$(echo "$INPUT" | jq -r '.tool_name')
    DETAIL=$(echo "$INPUT" | jq -r '.tool_input.command // .tool_input.file_path // ""' | head -c 100)
    terminal-notifier -title "$PROJECT" -subtitle "Claude PermissionRequest" -message "$TOOL: $DETAIL"
    afplay /System/Library/Sounds/Ping.aiff &
    ;;
  Stop)
    MSG=$(echo "$INPUT" | jq -r '.last_assistant_message // "Done"' | head -c 100)
    terminal-notifier -title "$PROJECT" -subtitle "Claude Stop" -message "$MSG"
    ;;
esac
